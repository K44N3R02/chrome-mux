{
    "manifest_version": 3,
    "name": "Chrome Mux",
    "version": "0.1",
    "description": "Manage your tabs with simple sessions, inspired by qutebrowser sessions",
    "action": {
        "default_popup": "html/popup.html",
        "default_icon": "assets/processor-icon.png"
    },
    "permissions": ["tabs", "storage"],
    "content_scripts": [

    ],
    "background": {
        "service_worker": "scripts/service-worker.js",
        "type": "module"
    },
    "options_ui": {
        "page": "html/settings.html",
        "open_in_tab": true
    },
    "minimum_chrome_version": "102",
    "omnibox": {
        "keyword": "mux"
    },
    "commands": {
        "_execute_action": {
            "suggested_key": {
                "default": "Ctrl+K",
                "mac": "Command+K"
            },
            "description": "Save currently active session (if there is any) and replace with a new session"
        }
    }
}
